const activities = [
  { type: "bieg", minutes: 35, calories: 320, intensity: "średnia" },
  { type: "rower", minutes: 50, calories: 410, intensity: "wysoka" },
  { type: "spacer", minutes: 20, calories: 90, intensity: "niska" },
  { type: "siłownia", minutes: 60, calories: 450, intensity: "wysoka" }
];

// 1. Łączny czas aktywności
const totalMinutes = activities.reduce((sum, activity) => {
  return sum + activity.minutes;
}, 0);

// 2. Łączna liczba kalorii
const totalCalories = activities.reduce((sum, activity) => {
  return sum + activity.calories;
}, 0);

// 3. Aktywności dłuższe niż 30 minut
const longActivities = activities.filter(activity => {
  return activity.minutes > 30;
});

// 4. Rozszerzenie własne – najbardziej kaloryczny trening
const topCaloriesActivity = activities.reduce((max, activity) => {
  return activity.calories > max.calories ? activity : max;
});

// 5. Raport tekstowy (template literals)
const report = `
=== RAPORT AKTYWNOŚCI ===

Łączny czas treningów: ${totalMinutes} minut
Łączna liczba spalonych kalorii: ${totalCalories} kcal
Liczba dłuższych aktywności: ${longActivities.length}

Najbardziej kaloryczny trening:
${topCaloriesActivity.type} - ${topCaloriesActivity.calories} kcal

Aktywności powyżej 30 minut:
${longActivities.map(activity =>
  `- ${activity.type} (${activity.minutes} min, intensywność: ${activity.intensity})`
).join("\n")}
`;

console.log(report);

/*
Komentarz:
- Użyto reduce() do obliczenia czasu i kalorii.
- Użyto filter() do wybrania aktywności powyżej 30 minut.
- Raport został zbudowany przez template literals.
- Rozszerzenie własne: dodatkowa cecha intensity oraz wykrywanie najbardziej kalorycznego treningu.
- Największa trudność: zachowanie czytelności raportu przy większej liczbie danych.
