const cart = [
  { name: 'Chleb', price: 4.5, quantity: 2, category: 'pieczywo' },
  { name: 'Ser', price: 9.9, quantity: 1, category: 'nabiał' },
  { name: 'Sok', price: 6.2, quantity: 3, category: 'napoje' },
];

const discountThreshold = 30;
const discountPercent = 10;

// funkcja pomocnicza (rozszerzenie)
function formatPrice(value) {
  return `${value.toFixed(2)} zł`;
}

// 1. map() – obliczenie wartości pozycji
const cartDetails = cart.map((product) => {
  return {
    ...product,
    total: Number((product.price * product.quantity).toFixed(2)),
  };
});

// 2. map() – tekstowe opisy pozycji
const itemDescriptions = cart.map((product) => {
  return `${product.quantity} × ${product.name} [${product.category}]`;
});

// 3. reduce() – suma koszyka
const totalBeforeDiscount = cartDetails.reduce((sum, product) => {
  return sum + product.total;
}, 0);

// 4. warunek rabatu
const hasDiscount = totalBeforeDiscount > discountThreshold;

const totalAfterDiscount = hasDiscount
  ? Number((totalBeforeDiscount * (1 - discountPercent / 100)).toFixed(2))
  : totalBeforeDiscount;

// 5. raport
console.log('=== RAPORT KOSZYKA ===');

console.log('\nProdukty:');
console.log(itemDescriptions);

console.log('\nWartość przed rabatem:');
console.log(formatPrice(totalBeforeDiscount));

console.log('\nCzy naliczono rabat:');
console.log(hasDiscount ? `Tak (${discountPercent}%)` : 'Nie');

console.log('\nWartość po rabacie:');
console.log(formatPrice(totalAfterDiscount));

/*
Komentarz:
- map() użyty do budowy opisów oraz wartości pozycji.
- reduce() użyty do obliczenia pełnej wartości koszyka.
- Dodano własną funkcję formatPrice() do estetycznego wyświetlania cen.
- Rozszerzenie własne: dodatkowa cecha category dla produktów.
- Największa trudność: poprawne zaokrąglenie wartości po rabacie.
