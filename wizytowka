// Obiekt użytkownika
const user = {
  firstName: "Michal",
  lastName: "Kawecki",
  city: "Siemianowice Slaskie",
  age: 24,
  fieldOfStudy: "Informatyka",
  hobby: "Siatkowka" 
};

// 1. Pełne imię i nazwisko
console.log(user.firstName + " " + user.lastName);

// 2. Komunikat opisowy (template literals)
console.log(`${user.firstName} mieszka w mieście ${user.city} i studiuje ${user.fieldOfStudy}.`);

// 3. Komunikat zależny od wieku
const isAdult = user.age >= 18;
console.log(isAdult ? "Użytkownik jest pełnoletni." : "Użytkownik nie jest pełnoletni.");

// 4. Wykorzystanie własnego pola
console.log(`${user.firstName} interesuje się ${user.hobby}.`);
